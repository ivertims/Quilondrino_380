// Program to calculate the first 10 digits of the Fibonacci sequence using a single while loop.

print "Fibonacci sequence using while loop:";
var a = 0;
var b = 1;
var count = 0;

// Using a while loop
while (count < 10) {
    print a;
    var temp = a;
    a = b;
    b = temp + b;
    count = count + 1;
}