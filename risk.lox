// Risk classification program (explicit condition breakdown).

var age = 61;
var is_smoking = true;
var has_medical_condition = true;

if (age < 18) {
    print "Ineligible";
} else if (age > 60) {
    print "high risk";
} else {
    if (is_smoking) {
        if (has_medical_condition) {
            print "high risk";
        } else {
            print "low risk";
        }
    } else {
        print "low risk";
    }
}